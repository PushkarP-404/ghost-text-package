{
  "name": "@pushkar/ghost-text",
  "version": "0.1.0",
  "description": "Animated dot-field text renderer — text decomposed into opposing-direction scrolling dot fields that create a 'ghost font' illusion on Canvas2D.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "cd demo && npm run dev",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ghost",
    "font",
    "text",
    "animation",
    "canvas",
    "dot-field",
    "particle",
    "react",
    "component"
  ],
  "author": "pushkar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pushkar/ghost-text-package.git"
  },
  "homepage": "https://github.com/pushkar/ghost-text-package#readme",
  "bugs": {
    "url": "https://github.com/pushkar/ghost-text-package/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsdown": "^0.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
